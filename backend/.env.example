APP_NAME=Jod-AI
DEBUG=true
LOG_LEVEL=INFO

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://jod-ai.local
OPENROUTER_SITE_NAME=Jod-AI

# Database
DATABASE_URL=postgresql+asyncpg://jod:jod_secret@localhost:5432/jod_ai
DATABASE_URL_SYNC=postgresql+psycopg2://jod:jod_secret@localhost:5432/jod_ai

# Context management
MAX_CONTEXT_TOKENS=128000
CONTEXT_COMPACTION_THRESHOLD=0.75

# File storage
FILE_STORAGE_PATH=./data/files
MAX_FILE_SIZE_MB=50
